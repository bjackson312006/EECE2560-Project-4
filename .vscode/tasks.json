{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-Wall",
                "-I${workspaceFolder}/Inc",
                "${workspaceFolder}/Src/main.cpp",
                "${workspaceFolder}/Src/board.cpp",
                "-o",
                "${workspaceFolder}/sudoku"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        }
    ]
}
